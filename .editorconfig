# EditorConfig docs: https://editorconfig.org/
# Properties reference: https://github.com/editorconfig/editorconfig/wiki/EditorConfig-Properties

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
indent_style = space
indent_size = 2
trim_trailing_whitespace = true
max_line_length = 120

[{Makefile,go.mod,go.sum,*.go}]
indent_style = tab

[*.md]
trim_trailing_whitespace = false
max_line_length = unset

[{*.yml,*.yaml}]
ij_any_spaces_within_braces = false
ij_any_spaces_within_brackets = false
